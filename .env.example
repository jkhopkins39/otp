# ─────────────────────────────────────────────────────────────────
# One Talent Productions — environment variables
# Copy this file to ".env.local" for local dev.
# Set all of these in Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
# Project Settings → API → Publishable (anon) key
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
# Project Settings → API → Secret key  (server-only — never expose to browser)
SUPABASE_SECRET_KEY="your-supabase-secret-key"

# ── Admin auth (managed via Supabase Auth) ────────────────────────
# No ADMIN_PASSWORD or SESSION_SECRET needed.
# Create the admin user in: Supabase Dashboard → Authentication → Users → Add user
# Then sign in at /admin/login with that email + password.

# ── Resend (contact form email) ───────────────────────────────────
# 1. Add your domain at resend.com/domains and verify DNS
# 2. Create an API key at resend.com/api-keys
# 3. Set the three vars below
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# The "from" address — must be on your verified Resend domain
RESEND_FROM_EMAIL="contact@onetalentproductions.com"
# Where contact form submissions are delivered
RESEND_TO_EMAIL="onetalentproductions@gmail.com"
