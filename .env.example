# ─────────────────────────────────────────────────────────────
# One Talent Productions — environment variables
# Copy this file to ".env.local" and fill in real values.
# .env.local is gitignored, so secrets never get committed.
# ─────────────────────────────────────────────────────────────

# The single admin password used to sign in at /admin/login.
# Choose something long and unique.
ADMIN_PASSWORD="change-me-to-a-strong-password"

# Secret used to sign the admin session cookie (HMAC key).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="generate-a-long-random-string"

# ── Blog database ────────────────────────────────────────────
# Local dev uses a SQLite file at ./data/otp.db automatically.
# Optional override:
# DATABASE_PATH="/absolute/path/to/otp.db"

# Vercel / production (required for persistent blog posts on serverless):
# Create a free database at https://turso.tech, then add:
# TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── Contact form (Web3Forms) ──────────────────────────────
# Get a free access key at https://web3forms.com
# Must be prefixed with NEXT_PUBLIC_ so the client component can read it.
NEXT_PUBLIC_WEB3FORMS_KEY="your-web3forms-access-key"
