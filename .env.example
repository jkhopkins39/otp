# ─────────────────────────────────────────────────────────────
# One Talent Productions — environment variables
# Copy this file to ".env.local" and fill in real values.
# .env.local is gitignored, so secrets never get committed.
# ─────────────────────────────────────────────────────────────

# The single admin password used to sign in at /admin/login.
# Choose something long and unique.
ADMIN_PASSWORD="change-me-to-a-strong-password"

# Secret used to sign the admin session cookie (HMAC key).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="generate-a-long-random-string"

# Optional: override where the SQLite database file is written.
# Defaults to ./data/otp.db
# DATABASE_PATH="/absolute/path/to/otp.db"
