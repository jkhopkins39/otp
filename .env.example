# ─────────────────────────────────────────────────────────────────
# One Talent Productions — environment variables
# Copy this file to ".env.local" and fill in real values.
# .env.local is gitignored, so secrets never get committed.
# ─────────────────────────────────────────────────────────────────

# ── Admin auth ───────────────────────────────────────────────────
# Single admin password used to sign in at /admin/login.
ADMIN_PASSWORD="change-me-to-a-strong-password"

# Secret used to sign the admin session cookie (HMAC key).
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="generate-a-long-random-string"

# ── Supabase database ─────────────────────────────────────────────
# Create a free project at https://supabase.com
# Then run supabase-schema.sql in the Supabase SQL editor.
# Project Settings → API → Project URL
SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
# Project Settings → API → Publishable key (safe to expose to client if needed)
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
# Project Settings → API → Secret key (server-only, never expose to client)
SUPABASE_SECRET_KEY="your-supabase-secret-key"

# ── Contact form (Web3Forms) ──────────────────────────────────────
# Get a free access key at https://web3forms.com
# Tip: use WEB3FORMS_KEY (server-only) — the API route reads it server-side.
# If you prefer a public key for some reason, NEXT_PUBLIC_WEB3FORMS_KEY also works.
WEB3FORMS_KEY="your-web3forms-access-key"
